---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <section>
    <div class="min-w-full">
      <div class="prose mb-8">
        <p class="mt-0">
          Columbia DSA is the local chapter site for Columbia Democratic Socialists
          of America. This site provides updates on events, organizing, and
          member resources.
        </p>
        <p>
          Learn more about our chapter, calendar, and resources from the links
          in the navigation above.
        </p>
      </div>
    </div>
  </section>
</Layout>
